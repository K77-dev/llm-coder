# ===========================
# LLM Configuration
# ===========================
LLM_MODEL=codellama:13b-instruct-q4_K_M
LLM_HOST=http://localhost:11434
LLM_FALLBACK=claude

# Claude API (optional fallback)
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-6

# ===========================
# Database
# ===========================
DB_PATH=~/.code-llm/vectors.db
DB_CACHE_PATH=~/.code-llm/cache.db

# ===========================
# Vector Search
# ===========================
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BATCH=32
VECTOR_DIMENSIONS=384

# ===========================
# Memory Management
# ===========================
MAX_MEMORY_MB=13000
CACHE_TTL=3600
LRU_CACHE_SIZE=500

# ===========================
# Logging
# ===========================
LOG_LEVEL=info
LOG_PATH=./logs

# ===========================
# Indexing
# ===========================
REPOS_TO_INDEX=java-backend,node-api,react-apps,angular-apps
REPOS_BASE_PATH=~/repos
INDEX_SCHEDULE=0 2 * * *
BATCH_SIZE=100

# ===========================
# App
# ===========================
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ===========================
# Optional: Fallback mode
# ===========================
# FALLBACK_ONLY=true  # Descomenta para usar só Claude API
