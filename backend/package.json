{
  "name": "@bbts/code-llm-backend",
  "version": "1.0.0",
  "description": "BBTS Code LLM - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max_old_space_size=4096' ts-node-dev --respawn --transpile-only -r dotenv/config src/index.ts dotenv_config_path=../.env",
